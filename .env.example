# Runtime configuration is provided through the OpenClaw plugin manifest config
# or the native tool context, not via environment variables.
#
# Example plugin config:
# {
#   "lifiBaseUrl": "https://li.quest/v1",
#   "integrator": "openclaw-intent-transfer",
#   "ensRpcUrl": "https://ethereum-rpc.publicnode.com",
#   "defaultSlippageBps": 100,
#   "simulateOnly": false,
#   "rpcUrls": {
#     "base": "https://base-rpc.example",
#     "arbitrum": "https://arb-rpc.example",
#     "optimism": "https://op-rpc.example"
#   },
#   "minNativeReserve": {
#     "base": "0.002",
#     "arbitrum": "0.002",
#     "optimism": "0.002"
#   }
# }
#
# Live execution signing comes from the local OpenClaw wallet, not from plugin config.
